# -----------------------------------------------------------
# Network controller credentials
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — this file is safe to commit.
# -----------------------------------------------------------

# Huawei HG8245W5 (main modem)
ROUTER_HUAWEI_IP=http://100.10.10.1
ROUTER_HUAWEI_USERNAME=admin
ROUTER_HUAWEI_PASSWORD=yourpassword
ROUTER_HUAWEI_TIMEOUT=8000

# Tenda N301 router
TENDA_N301_IP=http://192.168.1.3
TENDA_N301_USERNAME=admin
TENDA_N301_PASSWORD=yourpassword
TENDA_N301_TIMEOUT=8000

# Tenda F3 router
TENDA_F3_IP=http://192.168.1.4
TENDA_F3_USERNAME=admin
TENDA_F3_PASSWORD=yourpassword
TENDA_F3_TIMEOUT=8000

# IP Camera
CAMERA_IP=http://192.168.1.20
CAMERA_USERNAME=admin
CAMERA_PASSWORD=yourpassword
CAMERA_TIMEOUT=8000

# D-Link X1852E router
DLINK_X1852E_IP=http://100.10.10.10
